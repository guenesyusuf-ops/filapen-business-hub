# ==============================================================================
# Filapen Business Hub -- Production Environment Variables
# ==============================================================================
# Copy this to .env.production and fill in real values.
# NEVER commit .env.production to git.
# ==============================================================================

# ------------------------------------------------------------------------------
# Database (Supabase PostgreSQL with PgBouncer)
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10

# ------------------------------------------------------------------------------
# Auth (Clerk -- https://dashboard.clerk.com)
# ------------------------------------------------------------------------------
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------------------------
# Application URLs
# ------------------------------------------------------------------------------
APP_URL=https://app.filapen.com
API_URL=https://api.filapen.com
NEXT_PUBLIC_API_URL=https://api.filapen.com
WEBHOOK_BASE_URL=https://api.filapen.com

# ------------------------------------------------------------------------------
# Redis (Upstash -- optional for MVP)
# ------------------------------------------------------------------------------
REDIS_URL=rediss://default:xxxxxxxxxxxx@[region].upstash.io:6379

# ------------------------------------------------------------------------------
# Shopify Integration
# ------------------------------------------------------------------------------
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_orders,read_products,read_inventory

# ------------------------------------------------------------------------------
# Meta Ads Integration
# ------------------------------------------------------------------------------
META_APP_ID=
META_APP_SECRET=

# ------------------------------------------------------------------------------
# Google Ads Integration
# ------------------------------------------------------------------------------
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------
# 32-byte hex string for encrypting stored credentials (generate with: openssl rand -hex 32)
CREDENTIALS_ENCRYPTION_KEY=
# Secret for internal API-to-API authentication
API_SECRET=

# ------------------------------------------------------------------------------
# Runtime
# ------------------------------------------------------------------------------
NODE_ENV=production
PORT=4000
