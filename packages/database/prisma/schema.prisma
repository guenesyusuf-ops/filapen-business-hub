/// TimescaleDB hypertable partitioned on date
model AdMetric {
  id                   String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                String     @map("org_id") @db.Uuid
  adAccountId          String     @map("ad_account_id") @db.Uuid
  campaignId           String?    @map("campaign_id") @db.Uuid
  adsetId              String?    @map("adset_id") @db.VarChar(255)
  adId                 String?    @map("ad_id") @db.VarChar(255)
  date                 DateTime   @db.Date
  platform             AdPlatform
  spend                Decimal    @default(0) @db.Decimal(12, 2)
  impressions          Int        @default(0)
  clicks               Int        @default(0)
  conversions          Int        @default(0)
  conversionValue      Decimal    @default(0) @map("conversion_value") @db.Decimal(12, 2)
  cpc                  Decimal?   @db.Decimal(12, 4)
  cpm                  Decimal?   @db.Decimal(12, 4)
  ctr                  Decimal?   @db.Decimal(8, 6)
  roasPlatformReported Decimal?   @map("roas_platform_reported") @db.Decimal(10, 4)
  currency             String     @default("USD") @db.VarChar(3)
  createdAt            DateTime   @default(now()) @map("created_at") @db.Timestamptz

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  adAccount    AdAccount    @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  campaign     AdCampaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@unique([orgId, adAccountId, campaignId, adsetId, adId, date], map: "uq_ad_metric_composite")
  @@index([orgId])
  @@index([adAccountId])
  @@index([campaignId])
  @@index([orgId, date])
  @@index([orgId, platform, date])
  @@index([date])
  @@map("ad_metrics")
}

