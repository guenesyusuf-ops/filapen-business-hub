  orgId       String   @map("org_id") @db.Uuid
  name        String   @db.VarChar(255)
  category    String?  @db.VarChar(100)
  logoUrl     String?  @map("logo_url") @db.Text
  website     String?  @db.Text
  channels    String[] @default([])
  competitors String[] @default([])
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  mentions     BrandMention[]

  @@unique([orgId, name])
  @@index([orgId])
  @@map("brands")
}

model BrandMention {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId               String   @map("org_id") @db.Uuid
  brandId             String   @map("brand_id") @db.Uuid
  influencerProfileId String   @map("influencer_profile_id") @db.Uuid
  type                String   @db.VarChar(50)
  platform            String   @db.VarChar(50)
  postUrl             String?  @map("post_url") @db.Text
  mentionDate         DateTime @map("mention_date") @db.Date
  engagementRate      Decimal? @map("engagement_rate") @db.Decimal(5, 2)
  estimatedReach      Int?     @map("estimated_reach")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz

  brand             Brand             @relation(fields: [brandId], references: [id], onDelete: Cascade)
  influencerProfile InfluencerProfile @relation(fields: [influencerProfileId], references: [id], onDelete: Cascade)

  @@index([brandId])
  @@index([influencerProfileId])
  @@index([orgId, brandId])
  @@map("brand_mentions")
}

// =============================================================================
// ENUMS — Content Hub
// =============================================================================

enum ContentType {
  headline
  primary_text
  ugc_script
  video_concept
  hook
  cta
  brief
  landing_page
  social_caption

  @@map("content_type")
}

enum ContentStatus {
  draft
  in_review
  approved
  published
  archived

  @@map("content_status")
}

// =============================================================================
// CONTENT HUB MODELS
// =============================================================================

model BrandVoice {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId          String   @map("org_id") @db.Uuid
  name           String   @db.VarChar(255)
  description    String?  @db.Text
  toneAttributes Json?    @map("tone_attributes")
  examples       String[] @default([])
  bannedWords    String[] @default([]) @map("banned_words")
  isDefault      Boolean  @default(false) @map("is_default")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization  Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contentPieces ContentPiece[]

  @@index([orgId])
  @@map("brand_voices")
}

model ContentTemplate {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId          String?     @map("org_id") @db.Uuid
  name           String      @db.VarChar(255)
  type           ContentType
  promptTemplate String      @map("prompt_template") @db.Text
  variables      Json?       @default("[]")
  category       String?     @db.VarChar(100)
  productName    String?     @map("product_name") @db.VarChar(255)
  performanceNotes String?   @map("performance_notes") @db.Text
  isSystem       Boolean     @default(false) @map("is_system")
  usageCount     Int         @default(0) @map("usage_count")
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([type])
  @@index([productName])
  @@map("content_templates")
}

model ContentPiece {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String        @map("org_id") @db.Uuid
  type         ContentType
  title        String        @db.VarChar(255)
  body         String        @db.Text
  platform     String?       @db.VarChar(50)
  status       ContentStatus @default(draft)
  brandVoiceId String?       @map("brand_voice_id") @db.Uuid
  aiGenerated  Boolean       @default(false) @map("ai_generated")
  aiModel      String?       @map("ai_model") @db.VarChar(100)
  tags         String[]      @default([])
  rating       Int?
  campaign     String?       @db.VarChar(255)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  brandVoice   BrandVoice?  @relation(fields: [brandVoiceId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([orgId, type])
  @@index([orgId, status])
  @@map("content_pieces")
}

// =============================================================================
// WORK MANAGEMENT — Kanban Boards, Tasks, Comments, Attachments, Labels
// =============================================================================

model WmProject {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  name        String   @db.VarChar(255)
  description String?  @db.Text
  color       String?  @db.VarChar(20)
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  columns WmColumn[]
  tasks   WmTask[]
  members WmProjectMember[]
  labels       WmLabel[]
  chatMessages WmProjectChat[]

  @@index([orgId])
  @@map("wm_projects")
}

model WmProjectChat {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  userName  String   @map("user_name") @db.VarChar(255)
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  project WmProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("wm_project_chats")
}

model WmColumn {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String  @map("project_id") @db.Uuid
  name      String  @db.VarChar(100)
  color     String? @db.VarChar(20)
  position  Int     @default(0)

  project WmProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   WmTask[]

  @@index([projectId])
  @@map("wm_columns")
}

model WmTask {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId            String    @map("org_id") @db.Uuid
  projectId        String    @map("project_id") @db.Uuid
  columnId         String    @map("column_id") @db.Uuid
  parentTaskId     String?   @map("parent_task_id") @db.Uuid
  title            String    @db.VarChar(500)
  description      String?   @db.Text
  assigneeId       String?   @map("assignee_id") @db.Uuid
  createdById      String    @map("created_by_id") @db.Uuid
  priority         String    @default("medium") @db.VarChar(20)
  dueDate          DateTime? @map("due_date") @db.Date
  position         Int       @default(0)
  completed        Boolean   @default(false)
  completedAt      DateTime? @map("completed_at") @db.Timestamptz
  estimatedMinutes Int?      @map("estimated_minutes")
  color            String?   @db.VarChar(20)
  section          String?   @db.VarChar(100)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  project     WmProject     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  column      WmColumn      @relation(fields: [columnId], references: [id], onDelete: Cascade)
  parentTask  WmTask?       @relation("Subtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks    WmTask[]      @relation("Subtasks")
  comments    WmComment[]
  attachments WmAttachment[]
  taskLabels  WmTaskLabel[]
  activities  WmActivity[]

  @@index([projectId])
  @@index([columnId])
  @@index([assigneeId])
  @@map("wm_tasks")
}

model WmComment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  userName  String   @map("user_name") @db.VarChar(255)
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  task WmTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("wm_comments")
}

model WmAttachment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId     String   @map("task_id") @db.Uuid
  fileName   String   @map("file_name") @db.VarChar(255)
  fileUrl    String   @map("file_url") @db.Text
  storageKey String?  @map("storage_key") @db.Text
  fileSize   Int?     @map("file_size")
  fileType   String?  @map("file_type") @db.VarChar(50)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  task WmTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("wm_attachments")
}

model WmLabel {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String @map("project_id") @db.Uuid
  name      String @db.VarChar(50)
  color     String @db.VarChar(20)

  project    WmProject     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskLabels WmTaskLabel[]

  @@map("wm_labels")
}

model WmTaskLabel {
  taskId  String @map("task_id") @db.Uuid
  labelId String @map("label_id") @db.Uuid

  task  WmTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label WmLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@map("wm_task_labels")
}

model WmProjectMember {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String @map("project_id") @db.Uuid
  userId    String @map("user_id") @db.Uuid
  userName  String @map("user_name") @db.VarChar(255)
  role      String @default("member") @db.VarChar(20)

  project WmProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("wm_project_members")
}

model WmActivity {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  userName  String   @map("user_name") @db.VarChar(255)
  action    String   @db.VarChar(100)
  details   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  task WmTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([projectId])
  @@map("wm_activities")
}

model WmNotification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(255)
  message   String   @db.Text
  taskId    String?  @map("task_id") @db.Uuid
  projectId String?  @map("project_id") @db.Uuid
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId, read])
  @@map("wm_notifications")
}
