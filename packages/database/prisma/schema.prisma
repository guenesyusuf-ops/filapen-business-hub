// =============================================================================
// MODELS — Screen-Share Modul (LiveKit-basiertes Bildschirmteilen)
// =============================================================================

model ScreenShareSession {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId               String    @map("org_id") @db.Uuid
  hostUserId          String    @map("host_user_id") @db.Uuid
  /// Name des LiveKit-Rooms (entspricht typischerweise "ss-{sessionId}")
  livekitRoomId       String    @map("livekit_room_id") @db.VarChar(120)
  /// Optionaler Session-Titel den der Host beim Start angegeben hat
  sessionName         String?   @map("session_name") @db.VarChar(255)
  /// Audio des geteilten Bildschirms / Tabs mit teilen
  audioEnabled        Boolean   @default(false) @map("audio_enabled")
  /// Voice-Chat (Mikrofone der Teilnehmer) aktiviert
  voiceEnabled        Boolean   @default(false) @map("voice_enabled")
  /// Externer Gast-Link aktiv?
  isPublic            Boolean   @default(false) @map("is_public")
  /// 12-Zeichen Random-Token fuer /share/[token]
  publicToken         String?   @map("public_token") @db.VarChar(40)
  /// bcrypt-Hash falls Passwort gesetzt
  publicPasswordHash  String?   @map("public_password_hash") @db.VarChar(120)
  publicExpiresAt     DateTime? @map("public_expires_at") @db.Timestamptz
  /// 'active' | 'ended'
  status              String    @default("active") @db.VarChar(20)
  startedAt           DateTime  @default(now()) @map("started_at") @db.Timestamptz
  endedAt             DateTime? @map("ended_at") @db.Timestamptz

  organization        Organization              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  participants        ScreenShareParticipant[]

  @@unique([publicToken])
  @@index([orgId, status])
  @@index([hostUserId])
  @@map("screen_share_sessions")
}

model ScreenShareParticipant {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId   String    @map("session_id") @db.Uuid
  /// Null wenn Gast (anonym via public token beigetreten)
  userId      String?   @map("user_id") @db.Uuid
  /// Nur bei Gaesten gesetzt — Anzeigename den der Gast eingegeben hat
  guestName   String?   @map("guest_name") @db.VarChar(120)
  /// 'host' | 'viewer'
  role        String    @default("viewer") @db.VarChar(20)
  invitedAt   DateTime  @default(now()) @map("invited_at") @db.Timestamptz
  joinedAt    DateTime? @map("joined_at") @db.Timestamptz
  leftAt      DateTime? @map("left_at") @db.Timestamptz
  /// 'invited' | 'joined' | 'declined' | 'left'
  status      String    @default("invited") @db.VarChar(20)

  session     ScreenShareSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
  @@map("screen_share_participants")
}

// =============================================================================
// MODELS — Influencer Performance Tracking
// =============================================================================

/// Eine Zeile pro Influencer × Kampagne × Post. Die Haupt-Analytics-Tabelle
/// fuer das Performance-Tracking-Modul. Viele Felder sind optional (Daten
/// werden ueber die Zeit erfasst). Computed-Felder (ROAS, ROI, profit, CPA,
/// CPM, conversion rate, AOV, profit margin) werden im Service berechnet —
/// nicht in der DB — damit wir sie auch in Filtern/Aggregations nutzen koennen.
model InfluencerPerformanceEntry {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                  String   @map("org_id") @db.Uuid

  /// Optional Link zur Discovery-Datenbank (InfluencerProfile)
  influencerProfileId    String?  @map("influencer_profile_id") @db.Uuid

  // BASIC
  influencerName         String   @map("influencer_name") @db.VarChar(255)
  platform               String   @db.VarChar(50)
  category               String?  @db.VarChar(120)
  managerContact         String?  @map("manager_contact") @db.VarChar(255)
  profileUrl             String?  @map("profile_url") @db.Text
  followerCount          Int?     @map("follower_count")
  engagementRate         Decimal? @map("engagement_rate") @db.Decimal(7, 3)
  storyViews             Int?     @map("story_views")
  avgViews               Int?     @map("avg_views")
  country                String?  @db.VarChar(80)
  language               String?  @db.VarChar(50)

  // KAMPAGNE
  campaignName           String?  @map("campaign_name") @db.VarChar(255)
  postedAt               DateTime? @map("posted_at") @db.Timestamptz
  storyAt                DateTime? @map("story_at") @db.Timestamptz
  productName            String?  @map("product_name") @db.VarChar(255)
  discountCode           String?  @map("discount_code") @db.VarChar(80)
  discountPct            Decimal? @map("discount_pct") @db.Decimal(5, 2)
  landingPageUrl         String?  @map("landing_page_url") @db.Text
  affiliateLink          String?  @map("affiliate_link") @db.Text
  /// 'planned' | 'contacted' | 'negotiating' | 'booked' | 'posted' | 'completed' | 'cancelled' | 'blacklisted'
  status                 String   @default("planned") @db.VarChar(30)

  // KOSTEN
  influencerFee          Decimal  @default(0) @map("influencer_fee") @db.Decimal(12, 2)
  productCost            Decimal  @default(0) @map("product_cost") @db.Decimal(12, 2)
  shippingCost           Decimal  @default(0) @map("shipping_cost") @db.Decimal(12, 2)
  cogs                   Decimal  @default(0) @db.Decimal(12, 2)
  extraCost              Decimal  @default(0) @map("extra_cost") @db.Decimal(12, 2)

  // PERFORMANCE
  revenue                Decimal  @default(0) @db.Decimal(12, 2)
  orders                 Int      @default(0)
  clicks                 Int      @default(0)
  views                  Int      @default(0)
  profitMarginOverride   Decimal? @map("profit_margin_override") @db.Decimal(5, 2)

  // TRACKING
  trackingLink           String?  @map("tracking_link") @db.Text
  utmSource              String?  @map("utm_source") @db.VarChar(120)
  utmCampaign            String?  @map("utm_campaign") @db.VarChar(120)
  trackingStatus         String?  @map("tracking_status") @db.VarChar(30)
  attributionConfirmed   Boolean  @default(false) @map("attribution_confirmed")

  // CONTENT-ANALYSE
  hookWorked             Boolean? @map("hook_worked")
  ctaQuality             Int?     @map("cta_quality") @db.SmallInt
  videoQuality           Int?     @map("video_quality") @db.SmallInt
  brandingScore          Int?     @map("branding_score") @db.SmallInt
  performanceRating      Int?     @map("performance_rating") @db.SmallInt
  bookable               Boolean?

  // NOTIZEN
  learnings              String?  @db.Text
  whatWorked             String?  @map("what_worked") @db.Text
  whatDidntWork          String?  @map("what_didnt_work") @db.Text
  improvementIdeas       String?  @map("improvement_ideas") @db.Text

  // FLAGS
  whitelist              Boolean  @default(false)
  blacklist              Boolean  @default(false)

  createdById            String   @map("created_by_id") @db.Uuid
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, status])
  @@index([orgId, platform])
  @@index([orgId, postedAt(sort: Desc)])
  @@index([orgId, campaignName])
  @@map("influencer_performance_entries")
}

// ---------------------------------------------------------------------------
// Rechnungen / Invoices module
// ---------------------------------------------------------------------------
// Eingangsrechnungen (supplier invoices) — der Filapen-Workflow ist:
//   1. Datei hochladen (PDF/JPG/PNG) → R2-Storage
//   2. Claude Vision OCR füllt extrahierte Felder + setzt ocr_status = success
//   3. User reviewed Felder, korrigiert, speichert
//   4. Cron-Job aktualisiert status (open → due_soon → due_today → overdue)
//   5. User markiert als bezahlt → status = paid, paidAt gesetzt
// Jeder Schritt erzeugt einen InvoiceEvent für die Audit-Historie.

model Invoice {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId             String   @map("org_id") @db.Uuid

  // Lieferant (Supplier) — alle Felder optional, OCR füllt nach
  supplierName      String?  @map("supplier_name") @db.VarChar(255)
  supplierAddress   String?  @map("supplier_address") @db.Text
  supplierEmail     String?  @map("supplier_email") @db.VarChar(255)
  supplierPhone     String?  @map("supplier_phone") @db.VarChar(64)
  supplierWebsite   String?  @map("supplier_website") @db.VarChar(255)
  supplierVatId     String?  @map("supplier_vat_id") @db.VarChar(64)

  // Rechnungs-Header
  invoiceNumber     String?  @map("invoice_number") @db.VarChar(128)
  invoiceDate       DateTime? @map("invoice_date") @db.Date
  serviceDate       DateTime? @map("service_date") @db.Date
  dueDate           DateTime? @map("due_date") @db.Date
  paymentTerms      String?  @map("payment_terms") @db.VarChar(255)
  currency          String   @default("EUR") @db.VarChar(3)

  // Beträge
  netAmount         Decimal? @map("net_amount") @db.Decimal(12, 2)
  vatAmount         Decimal? @map("vat_amount") @db.Decimal(12, 2)
  grossAmount       Decimal? @map("gross_amount") @db.Decimal(12, 2)
  taxRate           Decimal? @map("tax_rate") @db.Decimal(5, 2)
  discountAmount    Decimal? @map("discount_amount") @db.Decimal(12, 2)

  // Zahlungs-Informationen
  iban              String?  @db.VarChar(64)
  bic               String?  @db.VarChar(32)
  bankName          String?  @map("bank_name") @db.VarChar(255)
  paymentReference  String?  @map("payment_reference") @db.VarChar(255)

  // Kategorisierung — als String damit User später custom Kategorien anlegen können
  category          String   @default("other") @db.VarChar(64)

  // Status + Zahlungs-Workflow
  status            String   @default("open") @db.VarChar(32)
  paidAt            DateTime? @map("paid_at") @db.Timestamptz
  paidById          String?  @map("paid_by_id") @db.Uuid
  paymentProofPath  String?  @map("payment_proof_path") @db.Text

  // Dokument (R2-Storage)
  fileName          String   @map("file_name") @db.VarChar(255)
  fileMime          String   @map("file_mime") @db.VarChar(128)
  fileSize          Int      @map("file_size")
  storagePath       String   @map("storage_path") @db.Text
  storageUrl        String?  @map("storage_url") @db.Text

  // OCR / Vision-Extraktion
  ocrStatus         String   @default("pending") @map("ocr_status") @db.VarChar(32)
  ocrRawText        String?  @map("ocr_raw_text") @db.Text
  ocrConfidence     Float?   @map("ocr_confidence")
  ocrError          String?  @map("ocr_error") @db.Text
  reviewed          Boolean  @default(false)

  // Sonstiges
  notes             String?  @db.Text
  uploadedById      String?  @map("uploaded_by_id") @db.Uuid
  archived          Boolean  @default(false)

  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  events            InvoiceEvent[]

  @@index([orgId])
  @@index([orgId, status])
  @@index([orgId, dueDate])
  @@index([orgId, supplierName])
  @@index([orgId, archived, status])
  @@index([orgId, invoiceNumber])
  @@map("invoices")
}

model InvoiceEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  invoiceId String   @map("invoice_id") @db.Uuid
  // type: uploaded, ocr_started, ocr_completed, ocr_failed, edited, status_changed,
  //       marked_paid, marked_unpaid, archived, restored, deleted, note_added
  type      String   @db.VarChar(64)
  actorId   String?  @map("actor_id") @db.Uuid
  note      String?  @db.Text
  metadata  Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, createdAt(sort: Desc)])
  @@index([orgId, createdAt(sort: Desc)])
  @@map("invoice_events")
}

model InvoiceSettings {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId               String   @unique @map("org_id") @db.Uuid
  // Tage vor Fälligkeit für Erinnerungen — z.B. [7, 3, 0] = 7d/3d/Tag-X
  reminderDaysBefore  Int[]    @default([7, 3, 0]) @map("reminder_days_before")
  // Empfänger der Erinnerungs-Mails (zusätzlich zum Uploader)
  reminderRecipients  String[] @default([]) @map("reminder_recipients")
  defaultCategory     String   @default("other") @map("default_category") @db.VarChar(64)
  // Aufbewahrungsfrist in Monaten (DE GoBD: 120 = 10 Jahre)
  retentionMonths     Int      @default(120) @map("retention_months")
  // Custom Kategorien (zusätzlich zu den Standard-Werten)
  customCategories    String[] @default([]) @map("custom_categories")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("invoice_settings")
}

// ---------------------------------------------------------------------------
// Retouren / Returns module
// ---------------------------------------------------------------------------
// Interner Workflow: Office legt Retoure an → Lager lädt Bilder hoch →
// Backoffice entscheidet (akzeptieren/ablehnen) → ggf. Erstattung tracken.
// Keine API-Anbindung, alles manuell.
//
// Status-Flow:
//   open → in_review (Lager hat Bilder hochgeladen + zur Pruefung geschoben)
//        → accepted | rejected (Backoffice-Entscheidung)
//        → refunded (Geld zurueck, optional Folge-Status zu accepted)
//
// Eine Retoure kann mehrere Positionen enthalten (ReturnItem).
// Bilder gelten auf Retouren-Ebene (Gesamtfotos, nicht pro Position).

model Return {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String   @map("org_id") @db.Uuid

  // Plattform: 'tiktok' | 'shopify'
  platform        String   @db.VarChar(32)

  // Bestellung
  orderNumber     String   @map("order_number") @db.VarChar(128)
  requestDate     DateTime @map("request_date") @db.Date

  // Kunde
  customerName    String?  @map("customer_name") @db.VarChar(255)
  customerEmail   String?  @map("customer_email") @db.VarChar(255)

  // Optional: Tracking der Retoure-Sendung (vom Kunden zu uns)
  trackingNumber  String?  @map("tracking_number") @db.VarChar(128)

  // Workflow
  status          String   @default("open") @db.VarChar(32)
  // open | in_review | accepted | rejected | refunded

  // Ablehnung
  rejectionReason String?  @map("rejection_reason") @db.VarChar(64)
  // used | customer_damaged | incomplete | wrong_product | other
  rejectionNote   String?  @map("rejection_note") @db.Text

  // Erstattung (optional)
  refundAmount    Decimal? @map("refund_amount") @db.Decimal(12, 2)
  refundDate      DateTime? @map("refund_date") @db.Date

  // Sonstiges
  damaged         Boolean  @default(false)
  notes           String?  @db.Text

  // Audit
  createdById     String?  @map("created_by_id") @db.Uuid
  decidedById     String?  @map("decided_by_id") @db.Uuid
  decidedAt       DateTime? @map("decided_at") @db.Timestamptz

  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  items           ReturnItem[]
  images          ReturnImage[]
  events          ReturnEvent[]

  @@index([orgId])
  @@index([orgId, platform, status])
  @@index([orgId, requestDate])
  @@index([orgId, orderNumber])
  @@index([orgId, customerName])
  @@index([orgId, status])
  @@map("returns")
}

model ReturnItem {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  returnId        String   @map("return_id") @db.Uuid

  // Produkt: entweder FK auf Katalog (productId) ODER freier Text — exklusiv
  productId       String?  @map("product_id") @db.Uuid
  productFreetext String?  @map("product_freetext") @db.VarChar(255)
  quantity        Int      @default(1)
  notes           String?  @db.Text

  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  return          Return   @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
  @@map("return_items")
}

model ReturnImage {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  returnId        String   @map("return_id") @db.Uuid

  fileName        String   @map("file_name") @db.VarChar(255)
  fileMime        String   @map("file_mime") @db.VarChar(128)
  fileSize        Int      @map("file_size")
  storagePath     String   @map("storage_path") @db.Text
  storageUrl      String?  @map("storage_url") @db.Text

  uploadedById    String?  @map("uploaded_by_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  return          Return   @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId, createdAt])
  @@map("return_images")
}

model ReturnEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  returnId  String   @map("return_id") @db.Uuid
  // type: created, status_changed, image_added, image_removed, item_added,
  //       item_removed, edited, accepted, rejected, refunded, note_added
  type      String   @db.VarChar(64)
  actorId   String?  @map("actor_id") @db.Uuid
  note      String?  @db.Text
  metadata  Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  return    Return   @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId, createdAt(sort: Desc)])
  @@index([orgId, createdAt(sort: Desc)])
  @@map("return_events")
}

// ---------------------------------------------------------------------------
// NFC4you — NFC-Baender fuer Kinder mit Notfall-Kontaktdaten
// ---------------------------------------------------------------------------
// Workflow:
//   1. Hub-User generiert Batch mit N Codes (z.B. 100 Stueck)
//   2. CSV-Export → an NFC-Tag-Lieferanten geben (vorprogrammierte Tags)
//   3. Verkauft Tags → Eltern aktivieren via Public-Frontend nfc4you.de
//   4. Verlorenes Kind: Finder scannt Band → Profil + Anruf-Button
//
// DSGVO:
//   - Kundendaten in eigener Tabelle nfc_activations
//   - Zugriff nur ueber 'nfc-customer-data' Permission
//   - Vollstaendiger Audit-Log fuer alle Zugriffe
//   - 24-Monate-Inaktivitaet → Auto-Reminder + 30 Tage spaeter Loeschung

model NfcBatch {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  name        String?  @db.VarChar(255)
  count       Int
  createdById String?  @map("created_by_id") @db.Uuid
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  bands       NfcBand[]

  @@index([orgId])
  @@index([orgId, createdAt(sort: Desc)])
  @@map("nfc_batches")
}

model NfcBand {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  batchId     String    @map("batch_id") @db.Uuid

  // 6-stelliger Code (a-z, 2-9 ohne O/0, I/1, l) — global eindeutig
  code        String    @unique @db.VarChar(32)

  // inactive (frisch) | active (aktiviert) | deleted (Daten geloescht, Band weiter scanbar)
  status      String    @default("inactive") @db.VarChar(32)

  activatedAt DateTime? @map("activated_at") @db.Timestamptz
  lastScanAt  DateTime? @map("last_scan_at") @db.Timestamptz
  scanCount   Int       @default(0) @map("scan_count")

  // Pre-Aktivierung: Band einem Kaeufer zugewiesen (per E-Mail)
  // → Hub kann Bulk-Mail mit Aktivierungs-URLs versenden
  assignedEmail   String?   @map("assigned_email") @db.VarChar(320)
  assignedAt      DateTime? @map("assigned_at") @db.Timestamptz
  assignmentNote  String?   @map("assignment_note") @db.VarChar(255)

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  batch       NfcBatch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  activation  NfcActivation?

  @@index([orgId])
  @@index([orgId, status])
  @@index([batchId])
  @@index([orgId, lastScanAt(sort: Desc)])
  @@index([assignedEmail])
  @@map("nfc_bands")
}

model NfcActivation {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bandId    String   @unique @map("band_id") @db.Uuid
  orgId     String   @map("org_id") @db.Uuid

  // Kunden-Daten — ALLE optional, Kunde fuellt was er will
  firstName String?  @map("first_name") @db.VarChar(120)
  lastName  String?  @map("last_name") @db.VarChar(120)
  phone     String?  @db.VarChar(64)
  phone2    String?  @db.VarChar(64)
  notes     String?  @db.Text
  street    String?  @db.VarChar(255)
  zip       String?  @db.VarChar(32)
  city      String?  @db.VarChar(120)

  // Optional — fuer Notifications oder spaetere PIN-Reset-Funktion
  email     String?  @db.VarChar(320)

  // PIN-basiertes Edit-System:
  // Wenn Kunde bei Aktivierung eine PIN vergibt (optional), kann er sich
  // spaeter unter /[code]/edit mit Code+PIN einloggen und Daten aendern/loeschen.
  // Bcrypt-Hash; Rate-Limiting via failedAttempts + lockedUntil.
  editPinHash       String?   @map("edit_pin_hash") @db.VarChar(120)
  editPinSetAt      DateTime? @map("edit_pin_set_at") @db.Timestamptz
  editPinFailedAttempts Int   @default(0) @map("edit_pin_failed_attempts")
  editPinLockedUntil DateTime? @map("edit_pin_locked_until") @db.Timestamptz

  // Magic-Link-Reset bei vergessener PIN — wird per E-Mail an die hinterlegte
  // Adresse versendet, 15 min gueltig, ein-Mal-verwendbar
  pinResetTokenHash      String?   @map("pin_reset_token_hash") @db.VarChar(120)
  pinResetTokenExpiresAt DateTime? @map("pin_reset_token_expires_at") @db.Timestamptz

  // Consent (DSGVO)
  consentGivenAt    DateTime @map("consent_given_at") @db.Timestamptz
  consentVersion    String?  @map("consent_version") @db.VarChar(32)
  // IP+UA bei Aktivierung — DSGVO-Audit + Schutz vor Missbrauch
  activationIp      String?  @map("activation_ip") @db.VarChar(64)
  activationUa      String?  @map("activation_ua") @db.Text

  // Auto-Cleanup: bei 24 Monaten ohne Edit → Reminder, 30 Tage spaeter Loeschung
  inactivityReminderSentAt DateTime? @map("inactivity_reminder_sent_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  band      NfcBand  @relation(fields: [bandId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, createdAt(sort: Desc)])
  @@index([email])
  @@map("nfc_activations")
}

model NfcAuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  bandId    String?  @map("band_id") @db.Uuid
  // batch_created, band_activated, public_scan, customer_view, customer_edit,
  // customer_delete, edit_link_sent, edit_link_used, auto_reminder, auto_delete
  type      String   @db.VarChar(64)
  actorId   String?  @map("actor_id") @db.Uuid     // null = public/anonymous
  ipAddress String?  @map("ip_address") @db.VarChar(64)
  userAgent String?  @map("user_agent") @db.Text
  metadata  Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([orgId, createdAt(sort: Desc)])
  @@index([bandId, createdAt(sort: Desc)])
  @@index([orgId, type, createdAt(sort: Desc)])
  @@map("nfc_audit_log")
}
