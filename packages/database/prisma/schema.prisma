model SalesOrder {
  id                      String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                   String           @map("org_id") @db.Uuid
  // Internal order number, auto-generated ("VK-2026-00001")
  orderNumber             String           @map("order_number") @db.VarChar(50)
  customerId              String           @map("customer_id") @db.Uuid
  // Customer's own order number (from the incoming PO)
  externalOrderNumber     String?          @map("external_order_number") @db.VarChar(100)
  orderDate               DateTime?        @map("order_date") @db.Timestamptz
  requiredDeliveryDate    DateTime?        @map("required_delivery_date") @db.Timestamptz
  contactPerson           String?          @map("contact_person") @db.VarChar(255)
  shippingAddress         Json?            @map("shipping_address") @db.JsonB
  billingAddress          Json?            @map("billing_address") @db.JsonB
  paymentTerms            String?          @map("payment_terms") @db.VarChar(255)
  currency                String           @default("EUR") @db.VarChar(3)
  totalNet                Decimal          @default(0) @map("total_net") @db.Decimal(12, 2)
  status                  SalesOrderStatus @default(draft)
  createdById             String           @map("created_by_id") @db.Uuid
  assignedToId            String?          @map("assigned_to_id") @db.Uuid
  // Status flag timestamps — set when the user clicks the toggle-badge
  confirmationSentAt      DateTime?        @map("confirmation_sent_at") @db.Timestamptz
  shippedAt               DateTime?        @map("shipped_at") @db.Timestamptz
  invoiceSentAt           DateTime?        @map("invoice_sent_at") @db.Timestamptz
  paidAt                  DateTime?        @map("paid_at") @db.Timestamptz
  // easybill references
  easybillConfirmationId  String?          @map("easybill_confirmation_id") @db.VarChar(100)
  easybillConfirmationPdfUrl String?       @map("easybill_confirmation_pdf_url") @db.Text
  easybillInvoiceId       String?          @map("easybill_invoice_id") @db.VarChar(100)
  easybillInvoicePdfUrl   String?          @map("easybill_invoice_pdf_url") @db.Text
  easybillDeliveryNoteId  String?          @map("easybill_delivery_note_id") @db.VarChar(100)
  easybillDeliveryNotePdfUrl String?       @map("easybill_delivery_note_pdf_url") @db.Text
  // Wann die Versandlabels (+ Lieferschein) per E-Mail an das Lager
  // verschickt wurden. Frontend zeigt darauf basierend "Labels ans Lager
  // versendet am DD.MM.YYYY" — sodass der User auf einen Blick sieht ob
  // das Lager schon Bescheid weiss.
  labelsSentToWarehouseAt DateTime?        @map("labels_sent_to_warehouse_at") @db.Timestamptz
  // Versand-Info (free-form carrier + tracking numbers[])
  shippingCarrierNote     String?          @map("shipping_carrier_note") @db.VarChar(255)
  trackingNumbers         String[]         @default([]) @map("tracking_numbers")
  // Source (nullable → SalesOrderDocument of kind=original)
  sourceDocumentId        String?          @map("source_document_id") @db.Uuid
  extractionConfidence    Float?           @map("extraction_confidence")
  notes                   String?          @db.Text
  createdAt               DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer     SalesCustomer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  lineItems    SalesOrderLineItem[]
  documents    SalesOrderDocument[]
  events       SalesOrderEvent[]
  reminders    SalesOrderReminder[]
  shipments    SalesOrderShipment[]

  @@unique([orgId, orderNumber], map: "uq_sales_order_org_number")
  @@index([orgId])
  @@index([orgId, status])
  @@index([orgId, requiredDeliveryDate])
  @@index([orgId, customerId])
  @@index([orgId, createdAt])
  @@map("sales_orders")
}

model SalesOrderLineItem {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                  String   @map("org_id") @db.Uuid
  orderId                String   @map("order_id") @db.Uuid
  position               Int      @default(1)
  title                  String   @db.VarChar(500)
  supplierArticleNumber  String?  @map("supplier_article_number") @db.VarChar(100)
  ean                    String?  @db.VarChar(50)
  // VKE (Einheiten pro Karton)
  unitsPerCarton         Int?     @map("units_per_carton")
  quantity               Int      @default(1)
  unitPriceNet           Decimal  @default(0) @map("unit_price_net") @db.Decimal(12, 4)
  lineNet                Decimal  @default(0) @map("line_net") @db.Decimal(12, 2)
  // Auto-matched to internal product (nullable)
  matchedProductVariantId String? @map("matched_product_variant_id") @db.Uuid
  // Teilsendung: wenn gesetzt, ist diese Position versendet (als Teil eines
  // SalesOrderShipment). NULL = noch offen. Nur EINE Sendung pro Position —
  // partielle Mengen pro Position sind aktuell nicht gefordert.
  shipmentId             String?  @map("shipment_id") @db.Uuid
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization    Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  order           SalesOrder          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  matchedVariant  ProductVariant?     @relation(fields: [matchedProductVariantId], references: [id], onDelete: SetNull)
  shipment        SalesOrderShipment? @relation(fields: [shipmentId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([orgId, ean])
  @@index([orgId, supplierArticleNumber])
  @@index([shipmentId])
  @@map("sales_order_line_items")
}

model SalesOrderDocument {
