/// TimescaleDB hypertable partitioned on date
/// Composite primary key: (org_id, date, channel)
model DailyAggregate {
  orgId                    String   @map("org_id") @db.Uuid
  date                     DateTime @db.Date
  channel                  Channel
  grossRevenue             Decimal  @default(0) @map("gross_revenue") @db.Decimal(14, 2)
  netRevenue               Decimal  @default(0) @map("net_revenue") @db.Decimal(14, 2)
  totalCogs                Decimal  @default(0) @map("total_cogs") @db.Decimal(14, 2)
  totalAdSpend             Decimal  @default(0) @map("total_ad_spend") @db.Decimal(14, 2)
  totalShippingCost        Decimal  @default(0) @map("total_shipping_cost") @db.Decimal(14, 2)
  totalPaymentFees         Decimal  @default(0) @map("total_payment_fees") @db.Decimal(14, 2)
  totalRefunds             Decimal  @default(0) @map("total_refunds") @db.Decimal(14, 2)
  totalDiscounts           Decimal  @default(0) @map("total_discounts") @db.Decimal(14, 2)
  totalFixedCostsAllocated Decimal  @default(0) @map("total_fixed_costs_allocated") @db.Decimal(14, 2)
  grossProfit              Decimal  @default(0) @map("gross_profit") @db.Decimal(14, 2)
  contributionMargin       Decimal  @default(0) @map("contribution_margin") @db.Decimal(14, 2)
  netProfit                Decimal  @default(0) @map("net_profit") @db.Decimal(14, 2)
  orderCount               Int      @default(0) @map("order_count")
  unitsSold                Int      @default(0) @map("units_sold")
  newCustomerCount         Int      @default(0) @map("new_customer_count")
  returningCustomerCount   Int      @default(0) @map("returning_customer_count")
  avgOrderValue            Decimal  @default(0) @map("avg_order_value") @db.Decimal(12, 2)
  refundCount              Int      @default(0) @map("refund_count")
  refundRate               Decimal  @default(0) @map("refund_rate") @db.Decimal(8, 6)
  blendedRoas              Decimal? @map("blended_roas") @db.Decimal(10, 4)
  blendedCac               Decimal? @map("blended_cac") @db.Decimal(12, 2)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, date, channel])
  @@index([orgId, date])
  @@index([orgId, channel, date])
  @@index([date])
  @@map("daily_aggregates")
}

