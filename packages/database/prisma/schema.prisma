  @@index([orgId])
  @@index([productId])
  @@index([sku])
  @@index([orgId, sku])
  @@map("product_variants")
}

/// TimescaleDB hypertable partitioned on placed_at
model Order {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId             String            @map("org_id") @db.Uuid
  shopId            String            @map("shop_id") @db.Uuid
  externalId        String            @map("external_id") @db.VarChar(255)
  orderNumber       String            @map("order_number") @db.VarChar(50)
  status            OrderStatus       @default(open)
  financialStatus   FinancialStatus   @default(pending) @map("financial_status")
  fulfillmentStatus FulfillmentStatus @default(unfulfilled) @map("fulfillment_status")
  customerId        String?           @map("customer_id") @db.VarChar(255)
  emailHash         String?           @map("email_hash") @db.Char(64)
  currency          String            @default("USD") @db.VarChar(3)
  subtotalPrice     Decimal           @default(0) @map("subtotal_price") @db.Decimal(12, 2)
  totalDiscounts    Decimal           @default(0) @map("total_discounts") @db.Decimal(12, 2)
  totalShipping     Decimal           @default(0) @map("total_shipping") @db.Decimal(12, 2)
  totalTax          Decimal           @default(0) @map("total_tax") @db.Decimal(12, 2)
  totalPrice        Decimal           @default(0) @map("total_price") @db.Decimal(12, 2)
  totalRefunded     Decimal           @default(0) @map("total_refunded") @db.Decimal(12, 2)
  paymentGateway    String?           @map("payment_gateway") @db.VarChar(100)
  isFirstOrder      Boolean           @default(false) @map("is_first_order")
  sourceName        String?           @map("source_name") @db.VarChar(100)
  tags              String[]          @default([])
  landingSite       String?           @map("landing_site") @db.Text
  referringSite     String?           @map("referring_site") @db.Text
  discountCodes     Json[]            @default([]) @map("discount_codes")
  countryCode       String?           @map("country_code") @db.VarChar(2)
  provinceCode      String?           @map("province_code") @db.VarChar(10)
  shippingAddress   Json?             @map("shipping_address") @db.JsonB
  customerName      String?           @map("customer_name") @db.VarChar(255)
  customerEmail     String?           @map("customer_email") @db.VarChar(320)
  customerPhone     String?           @map("customer_phone") @db.VarChar(50)
  placedAt          DateTime          @map("placed_at") @db.Timestamptz
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  organization  Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  shop          Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  lineItems     OrderLineItem[]
  refunds       Refund[]
  transactions  Transaction[]
  shippingCosts ShippingCost[]
  shipments     OrderShipment[]

  @@unique([orgId, externalId], map: "uq_order_org_external")
  @@index([orgId])
  @@index([shopId])
  @@index([orgId, placedAt])
  @@index([orgId, shopId, placedAt])
  @@index([orgId, status])
  @@index([orgId, financialStatus])
  @@index([emailHash])
  @@index([orgId, isFirstOrder, placedAt])
  @@index([placedAt])
  @@map("orders")
}

model OrderLineItem {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId             String   @map("org_id") @db.Uuid
  orderId           String   @map("order_id") @db.Uuid
  productVariantId  String?  @map("product_variant_id") @db.Uuid
  externalId        String   @map("external_id") @db.VarChar(255)
  title             String   @db.VarChar(500)
  sku               String?  @db.VarChar(255)
  quantity          Int
  unitPrice         Decimal  @default(0) @map("unit_price") @db.Decimal(12, 2)
