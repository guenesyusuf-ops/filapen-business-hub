// =============================================================================
// Filapen Business Hub - Finance Hub MVP
// PostgreSQL 16 + TimescaleDB + pgvector
// Multi-tenant with RLS via tenant_id (org_id)
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  output          = "../../../node_modules/.prisma/client"
  previewFeatures = ["postgresqlExtensions", "multiSchema"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto]
}

// =============================================================================
// ENUMS — Creator Hub
// =============================================================================

enum CreatorStatus {
  prospect
  outreach
  active
  inactive
  churned
  blacklisted

  @@map("creator_status")
}

enum DealType {
  ugc
  paid_post
  affiliate
  ambassador
  review

  @@map("deal_type")
}

enum DealStage {
  lead
  outreach
  negotiation
  contracted
  in_progress
  review
  completed
  cancelled

  @@map("deal_stage")
}

enum PaymentStatus {
  pending
  invoiced
  paid
  overdue

  @@map("payment_status")
}

enum BriefingStatus {
  draft
  sent
  acknowledged

  @@map("briefing_status")
}

// =============================================================================
// ENUMS — Finance Hub
// =============================================================================

enum PlanType {
  free
  starter
  growth
  enterprise

  @@map("plan_type")
}

enum UserRole {
  owner
  admin
  member
  viewer

  @@map("user_role")
}

enum UserStatus {
  pending
  active
  invited
  rejected
  suspended
  deactivated

  @@map("user_status")
}

enum IntegrationType {
  shopify
  meta_ads
  google_ads

  @@map("integration_type")
}

enum IntegrationStatus {
  connected
  disconnected
  error

  @@map("integration_status")
}

enum ShopPlatform {
  shopify

  @@map("shop_platform")
}

enum ProductStatus {
  active
  archived
  draft

  @@map("product_status")
}

enum OrderStatus {
  open
  closed
  cancelled

  @@map("order_status")
}

enum FinancialStatus {
  paid
  partially_paid
  refunded
  partially_refunded
  pending

  @@map("financial_status")
}

enum FulfillmentStatus {
  fulfilled
  partial
  unfulfilled

  @@map("fulfillment_status")
}

enum TransactionKind {
  sale
  refund
  capture
  void

  @@map("transaction_kind")
}

enum TransactionStatus {
  success
  failure
  pending

  @@map("transaction_status")
}

enum AdPlatform {
  meta
  google
  tiktok
  amazon

  @@map("ad_platform")
}

enum AdAccountStatus {
  active
  disabled
  unsettled

  @@map("ad_account_status")
}

enum CampaignStatus {
  active
  paused
  deleted
  archived

  @@map("campaign_status")
}

enum FixedCostCategory {
  software
  salary
  warehouse
  agency
  creator
  other

  @@map("fixed_cost_category")
}

enum Recurrence {
  monthly
  weekly
  quarterly
  annual
  one_time

  @@map("recurrence")
}

enum COGSImportStatus {
  processing
  completed
  failed

  @@map("cogs_import_status")
}

enum SyncType {
  webhook
  scheduled
  manual
  backfill

  @@map("sync_type")
}

enum SyncStatus {
  started
  completed
  failed

  @@map("sync_status")
}

enum AlertType {
  roas_below
  refund_spike
  spend_over_budget
  cogs_missing
  sync_failed

  @@map("alert_type")
}

enum AlertSeverity {
  info
  warning
  critical

  @@map("alert_severity")
}

enum AlertStatus {
  active
  acknowledged
  resolved

  @@map("alert_status")
}

enum Channel {
  shopify_dtc
  amazon
  tiktok
  meta_ads
  google_ads
  all

  @@map("channel")
}

// =============================================================================
// CORE / SHARED MODELS
// =============================================================================

model Organization {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(100)
  plan      PlanType @default(free)
  currency  String   @default("USD") @db.VarChar(3)
  timezone  String   @default("UTC") @db.VarChar(50)
  branding  Json     @default("{}")
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  users               User[]
  integrations        Integration[]
  shops               Shop[]
  products            Product[]
  productVariants     ProductVariant[]
  orders              Order[]
  orderLineItems      OrderLineItem[]
  refunds             Refund[]
  transactions        Transaction[]
  shippingCosts       ShippingCost[]
  adAccounts          AdAccount[]
  adCampaigns         AdCampaign[]
  adMetrics           AdMetric[]
  fixedCosts          FixedCost[]
  paymentMethodConfigs PaymentMethodConfig[]
  cogsImports         COGSImport[]
  dailyAggregates     DailyAggregate[]
  syncLogs            SyncLog[]
  alerts              Alert[]
  auditLogs           AuditLog[]
  creators            Creator[]
  deals               Deal[]
  briefings           Briefing[]
  creatorUploads      CreatorUpload[]
  creatorProjects     CreatorProject[]
  influencerProfiles  InfluencerProfile[]
  watchlists          Watchlist[]
  brands              Brand[]
  brandVoices         BrandVoice[]
  contentTemplates    ContentTemplate[]
  contentPieces       ContentPiece[]
  teamInvites         TeamInvite[]
  invitations         ProjectInvitation[]

  @@map("organizations")
}

model User {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId               String     @map("org_id") @db.Uuid
  clerkUserId         String     @default("") @map("clerk_user_id") @db.VarChar(255)
  email               String     @db.VarChar(320)
  name                String?    @db.VarChar(255)
  firstName           String?    @map("first_name") @db.VarChar(120)
  lastName            String?    @map("last_name") @db.VarChar(120)
  phone               String?    @db.VarChar(40)
  passwordHash        String?    @map("password_hash") @db.Text
  avatarUrl           String?    @map("avatar_url") @db.Text
  role                UserRole   @default(member)
  status              UserStatus @default(active)
  menuPermissions     String[]   @default([]) @map("menu_permissions")
  mustChangePassword  Boolean    @default(false) @map("must_change_password")
  lastActiveAt        DateTime?  @map("last_active_at") @db.Timestamptz
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamptz

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  auditLogs    AuditLog[]

  @@unique([orgId, clerkUserId], map: "uq_user_org_clerk")
  @@unique([orgId, email], map: "uq_user_org_email")
  @@index([orgId])
  @@index([clerkUserId])
  @@map("users")
}

model TeamInvite {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  email            String   @db.VarChar(255)
  role             UserRole @default(member)
  menuPermissions  String[] @default([]) @map("menu_permissions")
  tempPasswordHash String?  @map("temp_password_hash") @db.Text
  invitedBy        String   @map("invited_by") @db.Uuid
  status           String   @default("pending") @db.VarChar(20)
  expiresAt        DateTime @map("expires_at") @db.Timestamptz
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([email])
  @@map("team_invites")
}

model Integration {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String            @map("org_id") @db.Uuid
  type        IntegrationType
  status      IntegrationStatus @default(disconnected)
  credentials Json              @default("{}") @db.JsonB
  scopes      String[]          @default([])
  lastSyncedAt DateTime?        @map("last_synced_at") @db.Timestamptz
  syncCursor  Json?             @map("sync_cursor") @db.JsonB
  errorLog    Json[]            @default([]) @map("error_log")
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  shops        Shop[]
  adAccounts   AdAccount[]
  syncLogs     SyncLog[]

  @@unique([orgId, type], map: "uq_integration_org_type")
  @@index([orgId])
  @@index([orgId, type])
  @@map("integrations")
}

// =============================================================================
// CREATOR HUB MODELS
// =============================================================================

model Creator {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId          String        @map("org_id") @db.Uuid
  name           String        @db.VarChar(255)
  email          String?       @db.VarChar(255)
  phone          String?       @db.VarChar(100)
  platform       String?       @db.VarChar(50)
  handle         String?       @db.VarChar(255)
  followerCount  Int?          @map("follower_count")
  engagementRate Decimal?      @map("engagement_rate") @db.Decimal(5, 2)
  niche          String?       @db.VarChar(100)
  location       String?       @db.VarChar(255)
  avatarUrl      String?       @map("avatar_url") @db.Text
  ratePerPost    Decimal?      @map("rate_per_post") @db.Decimal(10, 2)
  ratePerVideo   Decimal?      @map("rate_per_video") @db.Decimal(10, 2)
  notes          String?       @db.Text
  tags           String[]      @default([])
  status         CreatorStatus @default(prospect)
  score          Int?          @default(0)
  totalDeals     Int           @default(0) @map("total_deals")
  totalSpend     Decimal       @default(0) @map("total_spend") @db.Decimal(12, 2)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  inviteCode    String?   @unique @map("invite_code") @db.VarChar(20)
  age           Int?
  kids          Boolean   @default(false)
  kidsAges      String?   @map("kids_ages") @db.VarChar(100)
  kidsOnVideo   Boolean   @default(false) @map("kids_on_video")
  compensation  String?   @db.VarChar(50)
  provision     String?   @db.VarChar(100)
  fixAmount     Decimal?  @map("fix_amount") @db.Decimal(10, 2)
  contracts     Json      @default("[]")
  creatorNotes  String?   @map("creator_notes") @db.Text
  lastLogin     DateTime? @map("last_login") @db.Timestamptz
  firstContact  String?   @map("first_contact") @db.VarChar(50)

  organization Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deals        Deal[]
  uploads      CreatorUpload[]
  chatMessages ChatMessage[]
  invitations    ProjectInvitation[]
  notifications  CreatorNotification[]

  @@unique([orgId, email], map: "uq_creator_org_email")
  @@index([orgId])
  @@index([orgId, status])
  @@index([orgId, niche])
  @@map("creators")
}

model CreatorNotification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  creatorId String   @map("creator_id") @db.Uuid
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(255)
  message   String   @db.Text
  read      Boolean  @default(false)
  metadata  Json?    @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId, read])
  @@map("creator_notifications")
}

model Deal {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId         String        @map("org_id") @db.Uuid
  creatorId     String        @map("creator_id") @db.Uuid
  title         String        @db.VarChar(255)
  type          DealType      @default(ugc)
  stage         DealStage     @default(lead)
  amount        Decimal?      @db.Decimal(10, 2)
  currency      String        @default("USD") @db.VarChar(10)
  paymentStatus PaymentStatus @default(pending) @map("payment_status")
  deliverables  Json?         @default("[]")
  startDate     DateTime?     @map("start_date") @db.Date
  deadline      DateTime?     @db.Date
  completedAt   DateTime?     @map("completed_at") @db.Timestamptz
  notes         String?       @db.Text
  tags          String[]      @default([])
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator      Creator      @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  briefings    Briefing[]

  @@index([orgId])
  @@index([orgId, stage])
  @@index([orgId, creatorId])
  @@map("deals")
}

model Briefing {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId      String         @map("org_id") @db.Uuid
  dealId     String?        @map("deal_id") @db.Uuid
  productId  String?        @map("product_id") @db.Uuid
  title      String         @db.VarChar(255)
  content    String?        @db.Text
  notes      String?        @db.Text
  guidelines Json?          @default("{}")
  references String[]       @default([])
  status     BriefingStatus @default(draft)
  createdAt  DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deal         Deal?                  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  product      Product?               @relation(fields: [productId], references: [id], onDelete: SetNull)
  attachments  BriefingAttachment[]

  @@index([orgId])
  @@index([dealId])
  @@index([productId])
  @@map("briefings")
}

model BriefingAttachment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  briefingId String   @map("briefing_id") @db.Uuid
  fileName   String   @map("file_name") @db.VarChar(255)
  fileUrl    String   @map("file_url") @db.Text
  fileType   String   @map("file_type") @db.VarChar(50)
  storageKey String?  @map("storage_key") @db.Text
  fileSize   Int?     @map("file_size")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  briefing Briefing @relation(fields: [briefingId], references: [id], onDelete: Cascade)

  @@index([briefingId])
  @@map("briefing_attachments")
}

model CreatorUpload {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  creatorId   String   @map("creator_id") @db.Uuid
  fileName    String   @map("file_name") @db.VarChar(500)
  fileUrl     String   @map("file_url") @db.Text
  fileType    String   @map("file_type") @db.VarChar(50)
  mimeType    String?  @map("mime_type") @db.VarChar(100)
  fileSize    BigInt?  @map("file_size")
  tab         String   @db.VarChar(50)
  category    String?  @db.VarChar(100)
  product     String?  @db.VarChar(255)
  label       String?  @db.VarChar(255)
  batch       String?  @db.VarChar(255)
  storageKey  String?  @map("storage_key") @db.Text
  seenByAdmin    Boolean   @default(false) @map("seen_by_admin")
  liveStatus     String?   @map("live_status") @db.VarChar(20)
  liveDate       DateTime? @map("live_date") @db.Date
  liveApprovedAt DateTime? @map("live_approved_at") @db.Timestamptz
  liveApprovedBy String?   @map("live_approved_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  organization Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator      Creator         @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  comments     UploadComment[]

  @@index([orgId, creatorId])
  @@index([creatorId, tab])
  @@index([orgId, liveStatus])
  @@map("creator_uploads")
}

model UploadComment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId         String   @map("org_id") @db.Uuid
  uploadId      String   @map("upload_id") @db.Uuid
  creatorId     String?  @map("creator_id") @db.Uuid
  authorRole    String   @map("author_role") @db.VarChar(20)
  authorName    String   @map("author_name") @db.VarChar(255)
  message       String   @db.Text
  readByAdmin   Boolean  @default(false) @map("read_by_admin")
  readByCreator Boolean  @default(false) @map("read_by_creator")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  upload CreatorUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([uploadId])
  @@index([creatorId])
  @@map("upload_comments")
}

model CreatorProject {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId          String    @map("org_id") @db.Uuid
  name           String    @db.VarChar(255)
  description    String?   @db.Text
  status         String    @default("active") @db.VarChar(50)
  deadline       DateTime? @db.Date
  creatorIds     String[]  @default([]) @map("creator_ids")
  tags           String[]  @default([])
  campaignType   String?   @map("campaign_type") @db.VarChar(50)
  action         String?   @db.Text
  startDate      DateTime? @map("start_date") @db.Date
  productId      String?   @map("product_id") @db.Uuid
  neededCreators Int       @default(0) @map("needed_creators")
  budget         Decimal?  @db.Decimal(12, 2)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  product      Product?            @relation(fields: [productId], references: [id], onDelete: SetNull)
  invitations  ProjectInvitation[]
  documents    ProjectDocument[]

  @@index([orgId])
  @@map("creator_projects")
}

model ProjectInvitation {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  creatorId   String    @map("creator_id") @db.Uuid
  status      String    @default("pending") @db.VarChar(20)
  invitedAt   DateTime  @default(now()) @map("invited_at") @db.Timestamptz
  respondedAt DateTime? @map("responded_at") @db.Timestamptz
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz
  message     String?   @db.Text

  organization Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project      CreatorProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator      Creator        @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([projectId, creatorId])
  @@index([orgId, status])
  @@index([creatorId, status])
  @@map("project_invitations")
}

model ProjectDocument {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  projectId  String   @map("project_id") @db.Uuid
  type       String   @db.VarChar(50)
  fileName   String   @map("file_name") @db.VarChar(255)
  fileUrl    String   @map("file_url") @db.Text
  storageKey String?  @map("storage_key") @db.Text
  fileSize   Int?     @map("file_size")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  project CreatorProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_documents")
}

model ChatMessage {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId         String   @map("org_id") @db.Uuid
  creatorId     String   @map("creator_id") @db.Uuid
  senderRole    String   @map("sender_role") @db.VarChar(20)
  senderName    String   @map("sender_name") @db.VarChar(255)
  message       String   @db.Text
  readByAdmin   Boolean  @default(false) @map("read_by_admin")
  readByCreator Boolean  @default(false) @map("read_by_creator")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@index([orgId, creatorId])
  @@map("chat_messages")
}

model CalendarNote {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId      String    @map("org_id") @db.Uuid
  date       DateTime  @db.Date
  content    String    @db.Text
  reminderAt DateTime? @map("reminder_at") @db.Timestamptz
  createdBy  String    @map("created_by") @db.VarChar(255)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([orgId, date])
  @@map("calendar_notes")
}

// =============================================================================
// FINANCE HUB MODELS
// =============================================================================

model Shop {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId         String       @map("org_id") @db.Uuid
  integrationId String       @map("integration_id") @db.Uuid
  platform      ShopPlatform @default(shopify)
  name          String       @db.VarChar(255)
  domain        String       @db.VarChar(255)
  currency      String       @default("USD") @db.VarChar(3)
  timezone      String       @default("UTC") @db.VarChar(50)
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  integration  Integration  @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  products     Product[]
  orders       Order[]

  @@unique([orgId, domain], map: "uq_shop_org_domain")
  @@index([orgId])
  @@index([integrationId])
  @@map("shops")
}

model Product {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId         String        @map("org_id") @db.Uuid
  shopId        String        @map("shop_id") @db.Uuid
  externalId    String        @map("external_id") @db.VarChar(255)
  title         String        @db.VarChar(500)
  description   String?       @db.Text
  handle        String?       @db.VarChar(500)
  sku           String?       @db.VarChar(255)
  imageUrl      String?       @map("image_url") @db.Text
  status        ProductStatus @default(active)
  category      String?       @db.VarChar(255)
  vendor        String?       @db.VarChar(255)
  internalNotes String?       @map("internal_notes") @db.Text
  internalTags  String[]      @default([]) @map("internal_tags")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  organization    Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  shop            Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  variants        ProductVariant[]
  creatorProjects CreatorProject[]
  briefings       Briefing[]

  @@unique([orgId, externalId], map: "uq_product_org_external")
  @@index([orgId])
  @@index([shopId])
  @@index([orgId, shopId])
  @@index([externalId])
  @@index([orgId, status])
  @@map("products")
}

