// MODELS — Documents Hub
// =============================================================================

model DocFolder {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  parentId    String?   @map("parent_id") @db.Uuid
  name        String    @db.VarChar(255)
  color       String?   @db.VarChar(30)
  description String?   @db.Text
  createdBy   String    @map("created_by") @db.Uuid
  locked      Boolean   @default(false)
  lockedBy    String?   @map("locked_by") @db.Uuid
  tags        String[]  @default([])
  trashedAt   DateTime? @map("trashed_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent       DocFolder?      @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     DocFolder[]     @relation("FolderTree")
  files        DocFile[]
  permissions  DocPermission[]
  activities   DocActivity[]   @relation("FolderActivities")
  favorites    DocFavorite[]   @relation("FolderFavorites")

  @@index([orgId])
  @@index([orgId, parentId])
  @@index([orgId, trashedAt])
  @@index([createdBy])
  @@map("doc_folders")
}

model DocFile {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId      String    @map("org_id") @db.Uuid
  folderId   String?   @map("folder_id") @db.Uuid
  fileName   String    @map("file_name") @db.VarChar(500)
  fileUrl    String    @map("file_url") @db.Text
  storageKey String?   @map("storage_key") @db.Text
  fileSize   BigInt?   @map("file_size")
  fileType   String?   @map("file_type") @db.VarChar(50)
  mimeType   String?   @map("mime_type") @db.VarChar(100)
  dimensions Json?     @db.JsonB
  createdBy  String    @map("created_by") @db.Uuid
  status     String    @default("draft") @db.VarChar(20)
  tags       String[]  @default([])
  metadata   Json?
  trashedAt  DateTime? @map("trashed_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  folder       DocFolder?       @relation(fields: [folderId], references: [id], onDelete: Cascade)
  versions     DocFileVersion[]
  activities   DocActivity[]    @relation("FileActivities")
  favorites    DocFavorite[]    @relation("FileFavorites")

  @@index([orgId])
  @@index([folderId])
  @@index([orgId, status])
  @@index([orgId, trashedAt])
  @@index([createdBy])
  @@map("doc_files")
}

model DocFileVersion {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fileId     String   @map("file_id") @db.Uuid
  versionNum Int      @default(1) @map("version_num")
  fileName   String   @map("file_name") @db.VarChar(500)
  fileUrl    String   @map("file_url") @db.Text
  storageKey String?  @map("storage_key") @db.Text
  fileSize   BigInt?  @map("file_size")
  createdBy  String   @map("created_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  file DocFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([fileId, versionNum])
  @@map("doc_file_versions")
}

model DocPermission {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  folderId  String   @map("folder_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  canRead   Boolean  @default(true) @map("can_read")
  canUpload Boolean  @default(false) @map("can_upload")
  canEdit   Boolean  @default(false) @map("can_edit")
  canDelete Boolean  @default(false) @map("can_delete")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  folder DocFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@unique([folderId, userId], map: "uq_doc_permission_folder_user")
  @@index([userId])
  @@map("doc_permissions")
}

model DocActivity {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  folderId  String?  @map("folder_id") @db.Uuid
  fileId    String?  @map("file_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  userName  String   @map("user_name") @db.VarChar(255)
  action    String   @db.VarChar(100)
  details   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  folder       DocFolder?   @relation("FolderActivities", fields: [folderId], references: [id], onDelete: SetNull)
  file         DocFile?     @relation("FileActivities", fields: [fileId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([orgId, createdAt])
  @@index([folderId])
  @@index([fileId])
  @@index([userId])
  @@map("doc_activities")
}

model DocFavorite {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  folderId  String?  @map("folder_id") @db.Uuid
  fileId    String?  @map("file_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  folder DocFolder? @relation("FolderFavorites", fields: [folderId], references: [id], onDelete: Cascade)
  file   DocFile?   @relation("FileFavorites", fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([userId, folderId], map: "uq_doc_favorite_user_folder")
  @@unique([userId, fileId], map: "uq_doc_favorite_user_file")
  @@index([userId])
  @@map("doc_favorites")
}

// =============================================================================
// PURCHASE / PROCUREMENT — Lieferanten, Bestellungen, Rechnungen, Zahlungen
// =============================================================================

enum PoStatus {
  draft
  ordered
  shipped
  invoiced
  partially_received
  received
  completed
  cancelled

  @@map("po_status")
}

enum PoPaymentStatus {
  unpaid
  partially_paid
  paid
  overpaid

  @@map("po_payment_status")
}

enum PoPaymentMethod {
  bank_transfer
  credit_card
  paypal
  sepa_debit
  cash
  other

  @@map("po_payment_method")
}

enum PoDocumentType {
  invoice
  proforma
  delivery_note
  receipt
  other

  @@map("po_document_type")
}

enum SupplierStatus {
  active
  inactive

  @@map("supplier_status")
}

model Supplier {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String         @map("org_id") @db.Uuid
  supplierNumber  String         @map("supplier_number") @db.VarChar(50)
  companyName     String         @map("company_name") @db.VarChar(255)
  contactName     String         @map("contact_name") @db.VarChar(255)
  email           String         @db.VarChar(320)
  phone           String         @db.VarChar(50)
  vatId           String?        @map("vat_id") @db.VarChar(50)
  taxNumber       String?        @map("tax_number") @db.VarChar(50)
  street          String?        @db.VarChar(255)
  zipCode         String?        @map("zip_code") @db.VarChar(20)
  city            String?        @db.VarChar(120)
  country         String?        @default("DE") @db.VarChar(2)
  iban            String?        @db.VarChar(50)
  bic             String?        @db.VarChar(20)
  bankName        String?        @map("bank_name") @db.VarChar(255)
  paymentTermDays Int?           @default(30) @map("payment_term_days")
  defaultCurrency String         @default("EUR") @map("default_currency") @db.VarChar(3)
  notes           String?        @db.Text
  status          SupplierStatus @default(active)
  createdById     String         @map("created_by_id") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  organization   Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy      User            @relation("SupplierCreator", fields: [createdById], references: [id])
  purchaseOrders PurchaseOrder[]

  @@unique([orgId, supplierNumber], map: "uq_supplier_org_number")
  @@index([orgId])
  @@index([orgId, status])
  @@index([orgId, companyName])
  @@map("suppliers")
}

model PurchaseOrder {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId            String          @map("org_id") @db.Uuid
  orderNumber      String          @map("order_number") @db.VarChar(50)
  supplierId       String          @map("supplier_id") @db.Uuid
  orderDate        DateTime        @map("order_date") @db.Date
  expectedDelivery DateTime?       @map("expected_delivery") @db.Date
  receivedAt       DateTime?       @map("received_at") @db.Timestamptz
  currency         String          @default("EUR") @db.VarChar(3)
  exchangeRate     Decimal?        @map("exchange_rate") @db.Decimal(12, 6)
  subtotal         Decimal         @default(0) @db.Decimal(14, 2)
  taxTotal         Decimal         @default(0) @map("tax_total") @db.Decimal(14, 2)
  shippingCost     Decimal?        @map("shipping_cost") @db.Decimal(14, 2)
  customsCost      Decimal?        @map("customs_cost") @db.Decimal(14, 2)
  totalAmount      Decimal         @default(0) @map("total_amount") @db.Decimal(14, 2)
  paidAmount       Decimal         @default(0) @map("paid_amount") @db.Decimal(14, 2)
  openAmount       Decimal         @default(0) @map("open_amount") @db.Decimal(14, 2)
  status           PoStatus        @default(draft)
  paymentStatus    PoPaymentStatus @default(unpaid) @map("payment_status")
  notes            String?         @db.Text
  internalNotes    String?         @map("internal_notes") @db.Text
  billingAddress   String?         @map("billing_address") @db.Text
  shippingAddress  String?         @map("shipping_address") @db.Text
  createdById      String          @map("created_by_id") @db.Uuid
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  createdBy    User                @relation("PurchaseOrderCreator", fields: [createdById], references: [id])
  items        PurchaseOrderItem[]
  invoices     PurchaseInvoice[]
  payments     Payment[]
  documents    PurchaseDocument[]
  auditLogs    PurchaseAuditLog[]
  shipments    Shipment[]

  @@unique([orgId, orderNumber], map: "uq_po_org_number")
  @@index([orgId])
  @@index([orgId, status])
  @@index([orgId, supplierId])
  @@index([orgId, orderDate])
  @@index([orgId, paymentStatus])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  purchaseOrderId  String   @map("purchase_order_id") @db.Uuid
  productId        String?  @map("product_id") @db.Uuid
  productVariantId String?  @map("product_variant_id") @db.Uuid
  productName      String   @map("product_name") @db.VarChar(500)
  sku              String?  @db.VarChar(255)
  quantity         Decimal  @db.Decimal(14, 3)
  unitPrice        Decimal  @map("unit_price") @db.Decimal(14, 4)
  vatRate          Decimal  @default(19) @map("vat_rate") @db.Decimal(5, 2)
  lineSubtotal     Decimal  @map("line_subtotal") @db.Decimal(14, 2)
  lineTax          Decimal  @map("line_tax") @db.Decimal(14, 2)
  lineTotal        Decimal  @map("line_total") @db.Decimal(14, 2)
  position         Int      @default(0)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  purchaseOrder PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  shipmentItems ShipmentItem[]

  @@index([purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_items")
}

model PurchaseInvoice {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String    @map("org_id") @db.Uuid
  purchaseOrderId String?   @map("purchase_order_id") @db.Uuid
  invoiceNumber   String    @map("invoice_number") @db.VarChar(100)
  invoiceDate     DateTime  @map("invoice_date") @db.Date
  dueDate         DateTime? @map("due_date") @db.Date
  amount          Decimal   @db.Decimal(14, 2)
  currency        String    @default("EUR") @db.VarChar(3)
  documentId      String?   @map("document_id") @db.Uuid
  createdById     String    @map("created_by_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  purchaseOrder PurchaseOrder?    @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  document      PurchaseDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@unique([orgId, invoiceNumber], map: "uq_invoice_org_number")
  @@index([orgId])
  @@index([orgId, invoiceDate])
  @@index([orgId, dueDate])
  @@index([purchaseOrderId])
  @@map("purchase_invoices")
}

model Payment {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId             String          @map("org_id") @db.Uuid
  purchaseOrderId   String          @map("purchase_order_id") @db.Uuid
  paymentDate       DateTime        @map("payment_date") @db.Date
  amount            Decimal         @db.Decimal(14, 2)
  currency          String          @default("EUR") @db.VarChar(3)
  method            PoPaymentMethod @default(bank_transfer)
  cardBrand         String?         @map("card_brand") @db.VarChar(20)
  reference         String?         @db.VarChar(255)
  note              String?         @db.Text
  receiptDocumentId String?         @map("receipt_document_id") @db.Uuid
  createdById       String          @map("created_by_id") @db.Uuid
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz

  purchaseOrder   PurchaseOrder     @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  receiptDocument PurchaseDocument? @relation("PaymentReceipt", fields: [receiptDocumentId], references: [id], onDelete: SetNull)
  createdBy       User              @relation("PaymentCreator", fields: [createdById], references: [id])

  @@index([orgId])
  @@index([orgId, paymentDate])
  @@index([purchaseOrderId])
  @@map("payments")
}

model PurchaseDocument {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String         @map("org_id") @db.Uuid
  purchaseOrderId String?        @map("purchase_order_id") @db.Uuid
  fileName        String         @map("file_name") @db.VarChar(500)
  fileUrl         String         @map("file_url") @db.Text
  storageKey      String         @map("storage_key") @db.Text
  fileSize        BigInt?        @map("file_size")
  mimeType        String         @map("mime_type") @db.VarChar(100)
  documentType    PoDocumentType @default(other) @map("document_type")
  uploadedById    String         @map("uploaded_by_id") @db.Uuid
  uploadedAt      DateTime       @default(now()) @map("uploaded_at") @db.Timestamptz

  purchaseOrder   PurchaseOrder?    @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  uploadedBy      User              @relation("DocUploader", fields: [uploadedById], references: [id])
  invoices        PurchaseInvoice[]
  paymentReceipts Payment[]         @relation("PaymentReceipt")

  @@index([orgId])
  @@index([orgId, purchaseOrderId])
  @@map("purchase_documents")
}

model PurchaseAuditLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String   @map("org_id") @db.Uuid
  purchaseOrderId String?  @map("purchase_order_id") @db.Uuid
  entityType      String   @map("entity_type") @db.VarChar(50)
  entityId        String   @map("entity_id") @db.Uuid
  action          String   @db.VarChar(50)
  changes         Json?    @db.JsonB
  userId          String   @map("user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  user          User           @relation("PoAuditUser", fields: [userId], references: [id])

  @@index([orgId])
  @@index([orgId, entityType, entityId])
  @@index([purchaseOrderId])
  @@map("purchase_audit_logs")
}

model Shipment {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String    @map("org_id") @db.Uuid
  purchaseOrderId String    @map("purchase_order_id") @db.Uuid
  trackingNumber  String?   @map("tracking_number") @db.VarChar(255)
  carrier         String?   @db.VarChar(255)
  shippedAt       DateTime? @map("shipped_at") @db.Date
  receivedAt      DateTime? @map("received_at") @db.Date
  notes           String?   @db.Text
  createdById     String    @map("created_by_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  purchaseOrder PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  createdBy     User           @relation("ShipmentCreator", fields: [createdById], references: [id])
  items         ShipmentItem[]

  @@index([orgId])
  @@index([purchaseOrderId])
  @@index([receivedAt])
  @@map("shipments")
}

model ShipmentItem {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shipmentId          String   @map("shipment_id") @db.Uuid
  purchaseOrderItemId String   @map("purchase_order_item_id") @db.Uuid
  quantity            Decimal  @db.Decimal(14, 3)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz

  shipment          Shipment          @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  purchaseOrderItem PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([purchaseOrderItemId])
  @@map("shipment_items")
}

// =============================================================================
// EMAIL MARKETING MODULE — Contacts, Events, Segments, Flows, Campaigns, Templates
// =============================================================================

enum MarketingConsent {
  never_subscribed
  subscribed
  confirmed
  unsubscribed

  @@map("marketing_consent")
}

enum SuppressionReason {
  unsubscribed
  bounced_hard
  bounced_soft
  complained
  manual

  @@map("suppression_reason")
}

enum MessageStatus {
  queued
  sending
  sent
  delivered
  failed
  bounced
  complained
  suppressed

  @@map("email_message_status")
}

enum EmailCampaignStatus {
  draft
  scheduled
  sending
  sent
  paused
  archived

  @@map("email_campaign_status")
}

enum FlowStatus {
  draft
  active
  paused
  archived

  @@map("flow_status")
}

enum FlowStepType {
  delay
  condition
  send_email
  end

  @@map("flow_step_type")
}

enum FlowTriggerType {
  customer_created
  order_placed
  checkout_started
  viewed_product
  added_to_cart
  segment_entered
  custom_event

  @@map("flow_trigger_type")
}

model Contact {
  id                     String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                  String           @map("org_id") @db.Uuid
  shopId                 String?          @map("shop_id") @db.Uuid
  shopifyCustomerId      String?          @map("shopify_customer_id") @db.VarChar(64)
  email                  String           @db.VarChar(320)
  firstName              String?          @map("first_name") @db.VarChar(120)
  lastName               String?          @map("last_name") @db.VarChar(120)
  phone                  String?          @db.VarChar(40)
  locale                 String?          @db.VarChar(10)
  country                String?          @db.VarChar(2)
  city                   String?          @db.VarChar(120)
  province               String?          @db.VarChar(120)
  zip                    String?          @db.VarChar(20)
  tags                   String[]         @default([])
  marketingConsent       MarketingConsent @default(never_subscribed) @map("marketing_consent")
  consentedAt            DateTime?        @map("consented_at") @db.Timestamptz
  doubleOptInConfirmedAt DateTime?        @map("doi_confirmed_at") @db.Timestamptz
  unsubscribedAt         DateTime?        @map("unsubscribed_at") @db.Timestamptz
  totalSpent             Decimal          @default(0) @map("total_spent") @db.Decimal(14, 2)
  ordersCount            Int              @default(0) @map("orders_count")
  firstOrderAt           DateTime?        @map("first_order_at") @db.Timestamptz
  lastOrderAt            DateTime?        @map("last_order_at") @db.Timestamptz
  avgOrderValue          Decimal          @default(0) @map("avg_order_value") @db.Decimal(14, 2)
  lastSeenAt             DateTime?        @map("last_seen_at") @db.Timestamptz
  anonymousId            String?          @map("anonymous_id") @db.VarChar(64)
  properties             Json?
  createdAt              DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  shop         Shop?            @relation(fields: [shopId], references: [id], onDelete: SetNull)
  events       MarketingEvent[]
  messages     EmailMessage[]
  enrollments  FlowEnrollment[]

  @@unique([orgId, email], map: "uq_contact_org_email")
  @@index([orgId])
  @@index([orgId, marketingConsent])
  @@index([shopifyCustomerId])
  @@index([anonymousId])
  @@index([orgId, lastOrderAt])
  @@index([orgId, totalSpent])
  @@map("marketing_contacts")
}

model MarketingEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  contactId   String?  @map("contact_id") @db.Uuid
  anonymousId String?  @map("anonymous_id") @db.VarChar(64)
  type        String   @db.VarChar(60)
  source      String   @default("shopify") @db.VarChar(30)
  payload     Json?
  externalId  String?  @map("external_id") @db.VarChar(100)
  occurredAt  DateTime @map("occurred_at") @db.Timestamptz
  receivedAt  DateTime @default(now()) @map("received_at") @db.Timestamptz

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([orgId, source, externalId], map: "uq_event_source_external")
  @@index([orgId, contactId, occurredAt])
  @@index([orgId, type, occurredAt])
  @@index([orgId, occurredAt])
  @@map("marketing_events")
}

model EmailSuppression {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String            @map("org_id") @db.Uuid
  email     String            @db.VarChar(320)
  reason    SuppressionReason
  note      String?           @db.Text
  sourceId  String?           @map("source_id") @db.VarChar(100)
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, email], map: "uq_suppress_org_email")
  @@index([orgId])
  @@map("email_suppressions")
}

model EmailTemplate {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  name         String   @db.VarChar(200)
  description  String?  @db.Text
  subject      String   @db.VarChar(500)
  previewText  String?  @map("preview_text") @db.VarChar(500)
  blocks       Json
  htmlOverride String?  @map("html_override") @db.Text
  createdById  String   @map("created_by_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organization        Organization              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaigns           EmailCampaign[]
  flowSteps           FlowStep[]
  shippingAutomations ShippingEmailAutomation[]

  @@index([orgId])
  @@map("email_templates")
}

model Segment {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String    @map("org_id") @db.Uuid
  name            String    @db.VarChar(200)
  description     String?   @db.Text
  rules           Json
  memberCount     Int       @default(0) @map("member_count")
  lastRefreshedAt DateTime? @map("last_refreshed_at") @db.Timestamptz
  createdById     String    @map("created_by_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaigns    EmailCampaign[]
  flows        Flow[]

  @@index([orgId])
  @@map("segments")
}

model EmailCampaign {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId             String              @map("org_id") @db.Uuid
  name              String              @db.VarChar(200)
  status            EmailCampaignStatus @default(draft)
  templateId        String?             @map("template_id") @db.Uuid
  segmentId         String?             @map("segment_id") @db.Uuid
  fromName          String              @map("from_name") @db.VarChar(200)
  fromEmail         String              @map("from_email") @db.VarChar(320)
  replyTo           String?             @map("reply_to") @db.VarChar(320)
  subjectSnapshot   String?             @map("subject_snapshot") @db.VarChar(500)
  consentMode       String              @default("subscribed") @map("consent_mode") @db.VarChar(20)
  scheduledAt       DateTime?           @map("scheduled_at") @db.Timestamptz
  sentAt            DateTime?           @map("sent_at") @db.Timestamptz
  recipientsCount   Int                 @default(0) @map("recipients_count")
  sentCount         Int                 @default(0) @map("sent_count")
  deliveredCount    Int                 @default(0) @map("delivered_count")
  openCount         Int                 @default(0) @map("open_count")
  uniqueOpenCount   Int                 @default(0) @map("unique_open_count")
  clickCount        Int                 @default(0) @map("click_count")
  uniqueClickCount  Int                 @default(0) @map("unique_click_count")
  bounceCount       Int                 @default(0) @map("bounce_count")
  unsubscribeCount  Int                 @default(0) @map("unsubscribe_count")
  revenueAttributed Decimal             @default(0) @map("revenue_attributed") @db.Decimal(14, 2)
  createdById       String              @map("created_by_id") @db.Uuid
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  template     EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  segment      Segment?       @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  messages     EmailMessage[]

  @@index([orgId])
  @@index([orgId, status])
  @@index([scheduledAt])
  @@map("email_campaigns")
}

model Flow {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId             String          @map("org_id") @db.Uuid
  name              String          @db.VarChar(200)
  description       String?         @db.Text
  status            FlowStatus      @default(draft)
  triggerType       FlowTriggerType @map("trigger_type")
  triggerConfig     Json?           @map("trigger_config")
  segmentId         String?         @map("segment_id") @db.Uuid
  reentryDays       Int             @default(30) @map("reentry_days")
  consentMode       String          @default("subscribed") @map("consent_mode") @db.VarChar(20)
  enrolledCount     Int             @default(0) @map("enrolled_count")
  completedCount    Int             @default(0) @map("completed_count")
  revenueAttributed Decimal         @default(0) @map("revenue_attributed") @db.Decimal(14, 2)
  createdById       String          @map("created_by_id") @db.Uuid
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  activatedAt       DateTime?       @map("activated_at") @db.Timestamptz

  organization Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  segment      Segment?         @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  steps        FlowStep[]
  enrollments  FlowEnrollment[]

  @@index([orgId])
  @@index([orgId, status])
  @@index([orgId, triggerType])
  @@map("flows")
}

model FlowStep {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  flowId        String       @map("flow_id") @db.Uuid
  type          FlowStepType
  position      Int
  delayHours    Int?         @map("delay_hours")
  condition     Json?
  templateId    String?      @map("template_id") @db.Uuid
  nextStepId    String?      @map("next_step_id") @db.Uuid
  nextIfTrueId  String?      @map("next_if_true_id") @db.Uuid
  nextIfFalseId String?      @map("next_if_false_id") @db.Uuid
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz

  flow        Flow             @relation(fields: [flowId], references: [id], onDelete: Cascade)
  template    EmailTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  enrollments FlowEnrollment[] @relation("CurrentStep")

  @@index([flowId, position])
  @@map("flow_steps")
}

model FlowEnrollment {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId             String    @map("org_id") @db.Uuid
  flowId            String    @map("flow_id") @db.Uuid
  contactId         String    @map("contact_id") @db.Uuid
  status            String    @default("active") @db.VarChar(20)
  currentStepId     String?   @map("current_step_id") @db.Uuid
  nextRunAt         DateTime? @map("next_run_at") @db.Timestamptz
  context           Json?
  revenueAttributed Decimal   @default(0) @map("revenue_attributed") @db.Decimal(14, 2)
  enrolledAt        DateTime  @default(now()) @map("enrolled_at") @db.Timestamptz
  completedAt       DateTime? @map("completed_at") @db.Timestamptz
  exitedAt          DateTime? @map("exited_at") @db.Timestamptz
  exitReason        String?   @map("exit_reason") @db.VarChar(100)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  flow         Flow         @relation(fields: [flowId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  currentStep  FlowStep?    @relation("CurrentStep", fields: [currentStepId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([flowId])
  @@index([contactId])
  @@index([status, nextRunAt])
  @@index([orgId, flowId, contactId])
  @@map("flow_enrollments")
}

model EmailMessage {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId             String        @map("org_id") @db.Uuid
  contactId         String        @map("contact_id") @db.Uuid
  campaignId        String?       @map("campaign_id") @db.Uuid
  flowId            String?       @map("flow_id") @db.Uuid
  flowStepId        String?       @map("flow_step_id") @db.Uuid
  subject           String        @db.VarChar(500)
  fromEmail         String        @map("from_email") @db.VarChar(320)
  toEmail           String        @map("to_email") @db.VarChar(320)
  providerMessageId String?       @map("provider_message_id") @db.VarChar(200)
  status            MessageStatus @default(queued)
  openedAt          DateTime?     @map("opened_at") @db.Timestamptz
  clickedAt         DateTime?     @map("clicked_at") @db.Timestamptz
  bouncedAt         DateTime?     @map("bounced_at") @db.Timestamptz
  complainedAt      DateTime?     @map("complained_at") @db.Timestamptz
  unsubscribedAt    DateTime?     @map("unsubscribed_at") @db.Timestamptz
  openCount         Int           @default(0) @map("open_count")
  clickCount        Int           @default(0) @map("click_count")
  scheduledAt       DateTime?     @map("scheduled_at") @db.Timestamptz
  sentAt            DateTime?     @map("sent_at") @db.Timestamptz
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz

  organization Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact      Contact             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  campaign     EmailCampaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  events       EmailMessageEvent[]

  @@index([orgId])
  @@index([orgId, contactId])
  @@index([campaignId])
  @@index([providerMessageId])
  @@index([sentAt])
  @@map("email_messages")
}

model EmailMessageEvent {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId  String   @map("message_id") @db.Uuid
  type       String   @db.VarChar(40)
  url        String?  @db.Text
  userAgent  String?  @map("user_agent") @db.Text
  ip         String?  @db.VarChar(45)
  occurredAt DateTime @default(now()) @map("occurred_at") @db.Timestamptz

  message EmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, type])
  @@map("email_message_events")
}

model EmailSettings {
  id                        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                     String   @unique @map("org_id") @db.Uuid
  fromName                  String?  @map("from_name") @db.VarChar(200)
  fromEmail                 String?  @map("from_email") @db.VarChar(320)
  replyTo                   String?  @map("reply_to") @db.VarChar(320)
  sendingDomain             String?  @map("sending_domain") @db.VarChar(255)
  domainVerified            Boolean  @default(false) @map("domain_verified")
  trackingDomain            String?  @map("tracking_domain") @db.VarChar(255)
  tokenSecret               String?  @map("token_secret") @db.VarChar(100)
  publicTrackingKey         String?  @unique @map("public_tracking_key") @db.VarChar(64)
  defaultConsentMode        String   @default("subscribed") @map("default_consent_mode") @db.VarChar(20)
  doubleOptInEnabled        Boolean  @default(true) @map("doi_enabled")
  maxEmailsPerContactPerDay Int      @default(3) @map("max_per_day")
  unsubscribeCopy           String?  @map("unsubscribe_copy") @db.Text
  footerHtml                String?  @map("footer_html") @db.Text
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("email_settings")
}

// =============================================================================
// SHIPPING / VERSAND MODULE — Carrier-abstrahiert, DHL-first
// =============================================================================

enum ShippingCarrier {
  dhl
  ups
  dpd
  hermes
  gls
  custom

  @@map("shipping_carrier")
}

enum CarrierAccountStatus {
  active
  inactive

  @@map("carrier_account_status")
}

enum OrderShipmentStatus {
  label_created
  handed_to_carrier
  in_transit
  out_for_delivery
  delivered
  delivery_failed
  ready_for_pickup
  returned
  exception
  cancelled

  @@map("order_shipment_status")
}

enum LabelFormat {
  pdf_a4
  pdf_100x150
  pdf_103x199
  zpl_100x150
  zpl_103x199

  @@map("label_format")
}

enum ShippingRuleAction {
  select_carrier
  select_method
  select_package
  block_shipment

  @@map("shipping_rule_action")
}

model CarrierAccount {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String               @map("org_id") @db.Uuid
  carrier     ShippingCarrier
  accountName String               @map("account_name") @db.VarChar(200)
  credentials Json                 @db.JsonB // Encrypted payload
  isDefault   Boolean              @default(false) @map("is_default")
  status      CarrierAccountStatus @default(active)
  senderData  Json?                @map("sender_data") @db.JsonB // from-address snapshot
  apiReady    Boolean              @default(false) @map("api_ready") // true once credentials are valid
  notes       String?              @db.Text
  createdById String               @map("created_by_id") @db.Uuid
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  shipments    OrderShipment[]

  @@index([orgId])
  @@index([orgId, carrier])
  @@map("carrier_accounts")
}

model ShippingPackage {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  name         String   @db.VarChar(200)
  lengthMm     Int      @map("length_mm")
  widthMm      Int      @map("width_mm")
  heightMm     Int      @map("height_mm")
  emptyWeightG Int      @default(0) @map("empty_weight_g")
  active       Boolean  @default(true)
  sortIndex    Int      @default(0) @map("sort_index")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  shipments    OrderShipment[]

  @@index([orgId])
  @@index([orgId, active])
  @@map("shipping_packages")
}

model ShippingRule {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String             @map("org_id") @db.Uuid
  name        String             @db.VarChar(200)
  description String?            @db.Text
  priority    Int                @default(100) // lower = higher priority
  conditions  Json               @db.JsonB // rule tree like segments
  actionType  ShippingRuleAction @map("action_type")
  actionValue Json               @map("action_value") @db.JsonB // { carrier, method, packageId }
  active      Boolean            @default(true)
  createdById String             @map("created_by_id") @db.Uuid
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, active, priority])
  @@map("shipping_rules")
}

model ShippingProductProfile {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId               String   @map("org_id") @db.Uuid
  productVariantId    String?  @unique @map("product_variant_id") @db.Uuid
  // Fallback for manual products not linked to ProductVariant
  sku                 String?  @db.VarChar(255)
  title               String?  @db.VarChar(500)
  weightG             Int      @default(0) @map("weight_g")
  // Optionales Override-Karton-Gewicht (z.B. fuer fertig vorgepackte Master-
  // kartons mit besonderer Verpackung). Wenn null, rechnet das System
  // weightG × VKE = Karton-Gewicht (ohne Verpackungs-Aufschlag).
  weightPerCartonG    Int?     @map("weight_per_carton_g")
  lengthMm            Int?     @map("length_mm")
  widthMm             Int?     @map("width_mm")
  heightMm            Int?     @map("height_mm")
  // Customs / international shipping
  hsCode              String?  @map("hs_code") @db.VarChar(20)
  countryOfOrigin     String?  @map("country_of_origin") @db.VarChar(2)
  customsValueCents   Int?     @map("customs_value_cents")
  customsCurrency     String?  @default("EUR") @map("customs_currency") @db.VarChar(3)
  // Options
  excludeFromShipping Boolean  @default(false) @map("exclude_from_shipping")
  notes               String?  @db.Text
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organization   Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([orgId, sku])
  @@index([productVariantId])
  @@map("shipping_product_profiles")
}

model OrderShipment {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId            String              @map("org_id") @db.Uuid
  orderId          String              @map("order_id") @db.Uuid
  carrier          ShippingCarrier
  carrierAccountId String?             @map("carrier_account_id") @db.Uuid
  packageId        String?             @map("package_id") @db.Uuid
  // Snapshot of recipient address at time of shipment
  recipientName    String              @map("recipient_name") @db.VarChar(255)
  recipientEmail   String?             @map("recipient_email") @db.VarChar(320)
  recipientPhone   String?             @map("recipient_phone") @db.VarChar(50)
  recipientAddress Json                @map("recipient_address") @db.JsonB
  senderAddress    Json?               @map("sender_address") @db.JsonB
  // Shipment meta
  shippingMethod   String?             @map("shipping_method") @db.VarChar(100)
  trackingNumber   String?             @map("tracking_number") @db.VarChar(100)
  trackingUrl      String?             @map("tracking_url") @db.Text
  weightG          Int                 @default(0) @map("weight_g")
  lengthMm         Int?                @map("length_mm")
  widthMm          Int?                @map("width_mm")
  heightMm         Int?                @map("height_mm")
  cost             Decimal?            @db.Decimal(12, 2)
  currency         String?             @db.VarChar(3)
  status           OrderShipmentStatus @default(label_created)
  // API mode: true if created via carrier API, false if manual (user entered tracking number)
  apiMode          Boolean             @default(false) @map("api_mode")
  notes            String?             @db.Text
  createdById      String              @map("created_by_id") @db.Uuid
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime            @updatedAt @map("updated_at") @db.Timestamptz
  handedOverAt     DateTime?           @map("handed_over_at") @db.Timestamptz
  deliveredAt      DateTime?           @map("delivered_at") @db.Timestamptz

  organization   Organization               @relation(fields: [orgId], references: [id], onDelete: Cascade)
  order          Order                      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  carrierAccount CarrierAccount?            @relation(fields: [carrierAccountId], references: [id], onDelete: SetNull)
  package        ShippingPackage?           @relation(fields: [packageId], references: [id], onDelete: SetNull)
  labels         OrderShipmentLabel[]
  statusEvents   OrderShipmentStatusEvent[]
  emailLogs      ShippingEmailLog[]

  @@index([orgId])
  @@index([orgId, status])
  @@index([orgId, createdAt])
  @@index([orderId])
  @@index([trackingNumber])
  @@map("order_shipments")
}

model OrderShipmentLabel {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shipmentId     String      @map("shipment_id") @db.Uuid
  sequenceNumber Int         @default(1) @map("sequence_number")
  trackingNumber String?     @map("tracking_number") @db.VarChar(100)
  format         LabelFormat @default(pdf_100x150)
  widthMm        Int?        @map("width_mm")
  heightMm       Int?        @map("height_mm")
  storageKey     String      @map("storage_key") @db.Text
  url            String      @db.Text
  rawContent     String?     @map("raw_content") @db.Text // ZPL etc. for direct thermal print
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz
  // Print-Tracking: printedAt wird beim ersten Druck gesetzt, printCount bei jedem weiteren
  printedAt      DateTime?   @map("printed_at") @db.Timestamptz
  printCount     Int         @default(0) @map("print_count")

  shipment OrderShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@map("order_shipment_labels")
}

model OrderShipmentStatusEvent {
  id         String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shipmentId String              @map("shipment_id") @db.Uuid
  status     OrderShipmentStatus
  note       String?             @db.Text
  rawData    Json?               @map("raw_data") @db.JsonB
  source     String              @default("api") @db.VarChar(20) // api | manual | polling | webhook
  occurredAt DateTime            @map("occurred_at") @db.Timestamptz
  createdAt  DateTime            @default(now()) @map("created_at") @db.Timestamptz

  shipment OrderShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, occurredAt])
  @@index([shipmentId, status])
  @@map("order_shipment_status_events")
}

model ShippingEmailAutomation {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId            String              @map("org_id") @db.Uuid
  triggerStatus    OrderShipmentStatus @map("trigger_status")
  // References an existing EmailTemplate from the Email Marketing module
  templateId       String?             @map("template_id") @db.Uuid
  subject          String?             @db.VarChar(500) // optional override
  enabled          Boolean             @default(false)
  sendDelayMinutes Int                 @default(0) @map("send_delay_minutes")
  updatedAt        DateTime            @updatedAt @map("updated_at") @db.Timestamptz
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz

  organization Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  template     EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@unique([orgId, triggerStatus], map: "uq_shipping_email_org_status")
  @@index([orgId, enabled])
  @@map("shipping_email_automations")
}

model ShippingEmailLog {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId          String              @map("org_id") @db.Uuid
  shipmentId     String              @map("shipment_id") @db.Uuid
  automationId   String?             @map("automation_id") @db.Uuid
  triggerStatus  OrderShipmentStatus @map("trigger_status")
  recipientEmail String              @map("recipient_email") @db.VarChar(320)
  subject        String              @db.VarChar(500)
  messageId      String?             @map("message_id") @db.VarChar(200) // EmailMessage id
  errorMessage   String?             @map("error_message") @db.Text
  sentAt         DateTime            @default(now()) @map("sent_at") @db.Timestamptz

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  shipment     OrderShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([shipmentId])
  @@map("shipping_email_logs")
}

// =============================================================================
// SALES MODULE — B2B order management with PDF/Mail import + easybill integration.
// Separate from Shopify `Order` model because B2B orders have different fields
// (VKE per carton, supplier article numbers, easybill document refs).
// =============================================================================

enum SalesOrderStatus {
  draft
  confirmed
  shipped
  invoiced
  completed
  cancelled

  @@map("sales_order_status")
}

enum SalesDocumentKind {
  original        // uploaded PDF/image of the incoming order
  confirmation    // Auftragsbestätigung (easybill PDF)
  invoice         // Rechnung (easybill PDF)
  delivery_note   // Lieferschein (easybill PDF)
  shipping_label  // DHL-Versandlabel (PDF pro Karton)
  other           // anything else the user attaches

  @@map("sales_document_kind")
}

enum SalesEventType {
  created
  imported
  edited
  confirmation_sent
  shipped
  invoice_sent
  paid
  note
  status_change

  @@map("sales_event_type")
}

enum SalesReminderKind {
  urgent_3d              // <=3 days to required delivery
  overdue                // past required delivery
  invoice_after_shipping // shipped but no invoice

  @@map("sales_reminder_kind")
}

model SalesCustomer {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                  String   @map("org_id") @db.Uuid
  // Internal customer number, auto-generated sequential ("KD-00001")
  customerNumber         String   @map("customer_number") @db.VarChar(50)
  // Customer-assigned number (optional, from their ERP)
  externalCustomerNumber String?  @map("external_customer_number") @db.VarChar(100)
  companyName            String   @map("company_name") @db.VarChar(255)
  contactPerson          String?  @map("contact_person") @db.VarChar(255)
  email                  String?  @db.VarChar(320)
  phone                  String?  @db.VarChar(50)
  shippingAddress        Json?    @map("shipping_address") @db.JsonB
  billingAddress         Json?    @map("billing_address") @db.JsonB
  paymentTerms           String?  @map("payment_terms") @db.VarChar(255)
  // B2B-Konditionen (global pro Kunde)
  minOrderQuantity       Int?     @map("min_order_quantity")
  minOrderValue          Decimal? @map("min_order_value") @db.Decimal(12, 2)
  discountPercent        Decimal? @map("discount_percent") @db.Decimal(5, 2)
  shippingTerms          String?  @map("shipping_terms") @db.VarChar(255)
  notes                  String?  @db.Text
  // easybill internal API ID (integer as string) — set after first successful upsert
  easybillCustomerId     String?  @map("easybill_customer_id") @db.VarChar(100)
  // easybill display customer number (e.g. "10191") — user-entered to match an
  // existing easybill customer so we don't create duplicates
  easybillCustomerNumber String?  @map("easybill_customer_number") @db.VarChar(50)
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organization  Organization                  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orders        SalesOrder[]
  productPrices SalesCustomerProductPrice[]

  @@unique([orgId, customerNumber], map: "uq_sales_customer_org_number")
  @@index([orgId])
  @@index([orgId, companyName])
  @@index([orgId, email])
  @@map("sales_customers")
}

/// Filapen Send — Datei-Transfer zwischen Team-Mitgliedern.
/// Eine Transfer-Row pro "Sendung", N Empfaenger (file_transfer_recipients),
/// N Dateien (file_transfer_items). Dateien liegen in R2.
model FileTransfer {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  senderId  String   @map("sender_id") @db.Uuid
  message   String?  @db.Text
  expiresAt DateTime? @map("expires_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  sender     User                    @relation("FileSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipients FileTransferRecipient[]
  items      FileTransferItem[]

  @@index([orgId])
  @@index([senderId])
  @@map("file_transfers")
}

model FileTransferRecipient {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transferId            String    @map("transfer_id") @db.Uuid
  recipientId           String    @map("recipient_id") @db.Uuid
  receivedAt            DateTime? @map("received_at") @db.Timestamptz
  deletedByRecipientAt  DateTime? @map("deleted_by_recipient_at") @db.Timestamptz
  // Welche Items dieser Empfaenger bereits heruntergeladen hat. Cleanup
  // greift erst wenn array.length == transfer.items.length — sonst gehen
  // Bulk-Downloads kaputt weil R2-Files vorzeitig geloescht wuerden.
  downloadedItemIds     String[]  @default([]) @map("downloaded_item_ids") @db.Uuid
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz

  transfer  FileTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  recipient User         @relation("FileRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([transferId, recipientId])
  @@index([recipientId])
  @@index([transferId])
  @@map("file_transfer_recipients")
}

model FileTransferItem {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transferId String   @map("transfer_id") @db.Uuid
  fileName   String   @map("file_name") @db.VarChar(500)
  filePath   String?  @map("file_path") @db.VarChar(1000)
  mimeType   String?  @map("mime_type") @db.VarChar(160)
  fileSize   BigInt   @map("file_size")
  storageKey String   @map("storage_key") @db.Text
  fileUrl    String   @map("file_url") @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  transfer FileTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([transferId])
  @@map("file_transfer_items")
}

